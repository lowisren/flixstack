# ============================================================
# Flixstack Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# ============================================================

# ContentStack — Required to serve live CMS data
# Get these from: ContentStack Dashboard → Stack → Settings → API Keys
NEXT_PUBLIC_CONTENTSTACK_API_KEY=
NEXT_PUBLIC_CONTENTSTACK_DELIVERY_TOKEN=
NEXT_PUBLIC_CONTENTSTACK_ENVIRONMENT=
NEXT_PUBLIC_CONTENTSTACK_REGION=
# Content branch to read from. Defaults to "main". Set to "model_v2" to preview
# the structured-content model before it is merged to main.
NEXT_PUBLIC_CONTENTSTACK_BRANCH=

# ContentStack Preview Token — Required for Live Preview / Visual Builder
# Get from: ContentStack Dashboard → Settings → Tokens → create/attach a Preview Token
# Server-only: do NOT prefix with NEXT_PUBLIC_ (must never reach the client bundle)
CONTENTSTACK_PREVIEW_TOKEN=

# ContentStack Management API — Required for the seed/upload-assets scripts only
# Get from: ContentStack Dashboard → Profile → Tokens → Management Token
# Server-only: do NOT prefix with NEXT_PUBLIC_
CONTENTSTACK_MANAGEMENT_TOKEN=

# ContentStack Webhook Secret — Optional, validates revalidation webhooks
# Server-only: do NOT prefix with NEXT_PUBLIC_
CONTENTSTACK_REVALIDATE_SECRET=

# Lytics — Optional, enables personalization
# Get from: Lytics Dashboard → Account Settings
NEXT_PUBLIC_CONTENTSTACK_LYTICS_ACCOUNT_ID=
NEXT_PUBLIC_CONTENTSTACK_LYTICS_API_KEY=
